server {
    listen 80;
    server_name sipp.macrocompany.net.pe;
    
    # Redirigir HTTP → HTTPS (después de certbot)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name sipp.macrocompany.net.pe;
    
    # SSL — certbot lo completará
    # ssl_certificate /etc/letsencrypt/live/sipp.macrocompany.net.pe/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/sipp.macrocompany.net.pe/privkey.pem;
    
    # Frontend Streamlit
    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400;
    }
    
    # Backend API en /api/
    location /api/ {
        proxy_pass http://127.0.0.1:8000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        client_max_body_size 50M;
    }
}
