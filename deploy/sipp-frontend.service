[Unit]
Description=SIPP Streamlit Frontend
After=network.target sipp-backend.service

[Service]
User=root
WorkingDirectory=/var/www/html/vygpack-sipp/frontend
EnvironmentFile=/var/www/html/vygpack-sipp/.env
Environment="TZ=America/Lima"
ExecStart=/var/www/html/vygpack-sipp/.venv/bin/streamlit run app.py \
    --server.port 8501 \
    --server.address 0.0.0.0 \
    --server.headless true \
    --server.fileWatcherType none
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
